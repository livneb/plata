# =========================================================================
# Plata — Environment Configuration
# Copy to .env and fill in. Each Railway container only needs a subset
# (see SERVICE_ENTRYPOINT + the topology table in the plan).
# =========================================================================

# --- Service selection (one of: ingestion_hub | intelligence_sandbox | execution_vault) ---
SERVICE_ENTRYPOINT=ingestion_hub
ENV=development          # development | staging | production

# --- Shared infrastructure (all containers) ---
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql+asyncpg://plata:plata@localhost:5432/plata

# --- LLM / Embeddings (intelligence_sandbox + execution_vault + scraper dedup) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
VOYAGE_API_KEY=

# --- Observability (all containers) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Scraper sources (ingestion_hub only) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=plata-scraper/0.1
CRYPTOPANIC_API_KEY=
NEWSAPI_KEY=
CRYPTONEWS_API_KEY=
LUNARCRUSH_API_KEY=
WHALEALERT_API_KEY=
# GDELT is keyless

# --- Trading (execution_vault ONLY — must NOT appear in other containers) ---
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# --- HITL (ingestion_hub) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=          # comma-separated chat IDs
DASHBOARD_SESSION_SECRET=           # random 64-char hex

# --- Bootstrap defaults (written to risk_config on first boot if empty) ---
DEFAULT_PAPER_TRADING_MODE=true
DEFAULT_RISK_PER_TRADE_PCT=1.0
DEFAULT_MAX_OPEN_POSITIONS=3
DEFAULT_MAX_DAILY_LOSS_PCT=5.0
DEFAULT_LLM_DAILY_BUDGET_USD=20.0
